$content = @'
<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="repository.meyistvision" name="Meyist Vision Repository" version="1.0.0" provider-name="Meyist">
        <requires>
            <import addon="xbmc.addon" version="12.0.0"/>
        </requires>
        <extension point="xbmc.addon.repository" name="Meyist Vision Repository">
            <dir minversion="20.0.0">
                <info compressed="false">https://raw.github.com/mmah47864/Meyist_Build/main/addons.xml</info>
                <checksum>https://raw.github.com/mmah47864/Meyist_Build/main/addons.xml.md5</checksum>
                <datadir zip="true">https://raw.github.com/mmah47864/Meyist_Build/main</datadir>
                <hashes>false</hashes>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="fr">Depot officiel Meyist Vision</summary>
            <platform>all</platform>
        </extension>
    </addon>
    <addon id="plugin.program.meyistvision" name="Meyist Vision Wizard" version="1.0.0" provider-name="Meyist">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
            <import addon="script.module.requests"/>
            <import addon="script.module.six"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="default.py">
            <provides>executable</provides>
        </extension>
        <extension point="xbmc.service" library="startup.py" start="startup"/>
        <extension point="xbmc.addon.metadata">
            <summary lang="fr">Wizard multimedia par Meyist</summary>
            <platform>all</platform>
        </extension>
    </addon>
</addons>
