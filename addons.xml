<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="repository.meyistvision" name="Meyist Vision Repository" version="1.0.0" provider-name="Meyist">
        <requires>
            <import addon="xbmc.addon.repository" version="1.0.0"/>
        </requires>
        <extension point="xbmc.addon.repository" name="Meyist Vision Repository">
            <info compressed="false">https://mmah47864.github.io/Meyist_Build/addons.xml</info>
            <checksum>https://mmah47864.github.io/Meyist_Build/addons.xml.md5</checksum>
            <datadir zip="true">https://mmah47864.github.io/Meyist_Build/</datadir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="fr">Depot officiel Meyist Vision</summary>
            <platform>all</platform>
        </extension>
    </addon>
    <addon id="plugin.program.meyistvision" name="Meyist Vision Wizard" version="1.0.0" provider-name="Meyist">
        <requires>
            <import addon="xbmc.python" version="3.0.0"/>
            <import addon="script.module.requests"/>
            <import addon="script.module.six"/>
        </requires>
        <extension point="xbmc.python.pluginsource" library="default.py">
            <provides>executable</provides>
        </extension>
        <extension point="xbmc.service" library="startup.py" start="startup"/>
        <extension point="xbmc.addon.metadata">
            <summary lang="fr">Wizard multimedia par Meyist</summary>
            <description lang="fr">Installez le build Meyist Vision pour une experience VOD et IPTV optimisee.</description>
            <platform>all</platform>
        </extension>
    </addon>
</addons>
